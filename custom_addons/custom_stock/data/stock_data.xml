<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Séquence contrôle qualité -->
        <record id="seq_stock_quality_check" model="ir.sequence">
            <field name="name">Contrôle qualité stock</field>
            <field name="code">stock.quality.check</field>
            <field name="prefix">QC/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <!-- Séquence projet de stock -->
        <record id="seq_stock_project" model="ir.sequence">
            <field name="name">Projet de stock</field>
            <field name="code">stock.project</field>
            <field name="prefix">PROJ/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <!-- Cron : Rafraîchir les données de réapprovisionnement intelligent -->
        <record id="ir_cron_refresh_intelligent_stock" model="ir.cron">
            <field name="name">Stock : Mise à jour réapprovisionnement intelligent</field>
            <field name="model_id" ref="model_stock_intelligent_reorder"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_stock_data()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
            <field name="numbercall">-1</field>
        </record>
    </data>
</odoo>
