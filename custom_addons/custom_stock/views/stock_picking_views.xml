<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extension vue formulaire picking -->
    <record id="view_stock_picking_form_custom" model="ir.ui.view">
        <field name="name">stock.picking.form.custom</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Boutons de workflow de préparation -->
            <xpath expr="//header" position="inside">
                <button name="action_start_preparation"
                        string="&#9654; Commencer préparation"
                        type="object" class="btn-primary"
                        invisible="preparation_status != 'not_started'"
                        help="Démarrer la préparation de cette commande"/>
                <button name="action_mark_ready"
                        string="&#9989; Prêt à expédier"
                        type="object" class="btn-success"
                        invisible="preparation_status != 'in_progress'"/>
                <button name="action_mark_shipped"
                        string="&#128666; Expédié"
                        type="object"
                        invisible="preparation_status != 'ready'"/>
                <button name="action_create_quality_checks"
                        string="&#128270; Créer contrôles qualité"
                        type="object" class="btn-secondary"
                        invisible="quality_check_required"
                        help="Générer automatiquement un contrôle qualité par produit"/>
            </xpath>

            <!-- Champs de suivi après l'origine -->
            <xpath expr="//field[@name='origin']" position="after">
                <field name="priority_custom" widget="priority"/>
                <field name="preparation_status" widget="badge"
                       decoration-info="preparation_status == 'not_started'"
                       decoration-warning="preparation_status == 'in_progress'"
                       decoration-success="preparation_status in ('ready', 'shipped')"/>
                <field name="carrier_tracking" placeholder="N° de suivi transporteur"
                       help="Référence de suivi du transporteur (DHL, TNT, etc.)"/>
            </xpath>

            <!-- Onglets de préparation et qualité -->
            <xpath expr="//notebook" position="inside">
                <page string="&#128230; Préparation" name="preparation">
                    <group>
                        <group string="Scan &amp; Mesures">
                            <field name="barcode_scanned" placeholder="Scanner un code-barres..."
                                   help="Scannez le code-barres du produit pour validation rapide"/>
                            <field name="package_count" help="Nombre de colis préparés"/>
                            <field name="weight_total" help="Poids total calculé de l'envoi (kg)"/>
                        </group>
                        <group string="Qualité">
                            <field name="quality_check_required" widget="boolean_toggle"
                                   help="Activer le contrôle qualité pour cette opération"/>
                            <field name="quality_status" widget="badge"
                                   decoration-success="quality_status == 'passed'"
                                   decoration-danger="quality_status == 'failed'"
                                   decoration-warning="quality_status == 'pending'"/>
                        </group>
                    </group>
                    <group>
                        <field name="preparation_notes"
                               placeholder="Notes internes de préparation..."
                               help="Instructions pour l'équipe de préparation"/>
                        <field name="delivery_instructions"
                               placeholder="Instructions spéciales de livraison (adresse, horaires, contact...)"
                               help="Instructions visibles sur le bon de livraison"/>
                    </group>
                </page>
                <page string="&#128270; Contrôles qualité" name="quality_checks"
                      invisible="not quality_check_required">
                    <div class="alert alert-warning" role="alert" style="margin-bottom:10px;">
                        <i class="fa fa-exclamation-triangle"/> Vérifiez chaque ligne et marquez le résultat. Toutes les lignes doivent être validées avant expédition.
                    </div>
                    <field name="quality_check_ids">
                        <tree editable="bottom"
                              decoration-success="result == 'pass'"
                              decoration-danger="result == 'fail'"
                              decoration-muted="result == 'pending'">
                            <field name="name" string="Réf."/>
                            <field name="product_id"/>
                            <field name="lot_id" string="Lot/Série" optional="show"/>
                            <field name="quantity" string="Qté prévue"/>
                            <field name="quantity_checked" string="Qté contrôlée"/>
                            <field name="quantity_failed" string="Qté rejetée"
                                   decoration-danger="quantity_failed > 0"/>
                            <field name="check_type" string="Type"/>
                            <field name="inspector_id" string="Inspecteur" widget="many2one_avatar_user"/>
                            <field name="result" widget="badge"
                                   decoration-success="result == 'pass'"
                                   decoration-danger="result == 'fail'"
                                   decoration-warning="result == 'pending'"/>
                            <button name="action_pass" string="Conforme"
                                    type="object" icon="fa-check-circle"
                                    class="text-success"
                                    invisible="result != 'pending'"/>
                            <button name="action_fail" string="Non conforme"
                                    type="object" icon="fa-times-circle"
                                    class="text-danger"
                                    invisible="result != 'pending'"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extension vue liste picking -->
    <record id="view_stock_picking_tree_custom" model="ir.ui.view">
        <field name="name">stock.picking.tree.custom</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="priority_custom" widget="priority"/>
                <field name="preparation_status" optional="show" widget="badge"
                       string="Préparation"
                       decoration-info="preparation_status == 'not_started'"
                       decoration-warning="preparation_status == 'in_progress'"
                       decoration-success="preparation_status in ('ready', 'shipped')"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <field name="quality_status" optional="show" widget="badge"
                       string="Qualité"
                       decoration-success="quality_status == 'passed'"
                       decoration-danger="quality_status == 'failed'"/>
                <field name="carrier_tracking" optional="hide" string="Tracking"/>
            </xpath>
        </field>
    </record>
</odoo>
