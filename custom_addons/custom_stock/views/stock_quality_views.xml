<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire contrôle qualité -->
    <record id="view_stock_quality_check_form" model="ir.ui.view">
        <field name="name">stock.quality.check.form</field>
        <field name="model">stock.quality.check</field>
        <field name="arch" type="xml">
            <form string="Contrôle qualité">
                <header>
                    <button name="action_pass" string="&#9989; Valider"
                            type="object" class="btn-success"
                            invisible="result != 'pending'"
                            help="Marquer ce contrôle comme conforme"/>
                    <button name="action_fail" string="&#10060; Échouer"
                            type="object" class="btn-danger"
                            invisible="result != 'pending'"
                            confirm="Confirmer l'échec de ce contrôle qualité ?"/>
                    <button name="action_reset" string="&#128260; Réinitialiser"
                            type="object"
                            invisible="result == 'pending'"/>
                    <field name="result" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="&#128230; Produit">
                            <field name="picking_id"
                                   help="Opération de stock associée"/>
                            <field name="product_id"
                                   help="Produit contrôlé"/>
                            <field name="lot_id"
                                   help="Numéro de lot ou de série"/>
                            <field name="check_type"
                                   help="Type de contrôle : visuel, dimensionnel, fonctionnel..."/>
                        </group>
                        <group string="&#128202; Mesures">
                            <field name="quantity"
                                   help="Quantité attendue"/>
                            <field name="quantity_checked"
                                   help="Quantité effectivement contrôlée"/>
                            <field name="quantity_failed"
                                   help="Quantité non conforme"
                                   decoration-danger="quantity_failed > 0"/>
                            <field name="inspector_id" widget="many2one_avatar_user"
                                   help="Inspecteur ayant réalisé le contrôle"/>
                            <field name="check_date"
                                   help="Date du contrôle"/>
                            <field name="team_id"
                                   help="Équipe qualité responsable"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="&#128221; Observations">
                            <field name="notes"
                                   placeholder="Défaut constaté, mesures correctives proposées, photos à joindre..."
                                   help="Détails et observations du contrôle qualité"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue liste contrôle qualité -->
    <record id="view_stock_quality_check_tree" model="ir.ui.view">
        <field name="name">stock.quality.check.tree</field>
        <field name="model">stock.quality.check</field>
        <field name="arch" type="xml">
            <tree string="Contrôles qualité"
                  decoration-success="result == 'pass'"
                  decoration-danger="result == 'fail'"
                  decoration-warning="result == 'pending'">
                <field name="name" string="Réf."/>
                <field name="picking_id" string="Opération"/>
                <field name="product_id"/>
                <field name="lot_id" optional="show" string="Lot/Série"/>
                <field name="check_type" string="Type"/>
                <field name="quantity" string="Qté prévue"/>
                <field name="quantity_checked" string="Qté contrôlée"/>
                <field name="quantity_failed" string="Qté rejetée"
                       decoration-danger="quantity_failed > 0"/>
                <field name="inspector_id" widget="many2one_avatar_user" string="Inspecteur"/>
                <field name="check_date" string="Date"/>
                <field name="result" widget="badge" string="Résultat"
                       decoration-success="result == 'pass'"
                       decoration-danger="result == 'fail'"
                       decoration-warning="result == 'pending'"/>
            </tree>
        </field>
    </record>

    <!-- Action contrôle qualité -->
    <record id="action_stock_quality_check" model="ir.actions.act_window">
        <field name="name">Contrôles qualité</field>
        <field name="res_model">stock.quality.check</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun contrôle qualité
            </p>
            <p>
                Les contrôles qualité sont créés automatiquement
                lors de la préparation des transferts.
            </p>
        </field>
    </record>

    <!-- Vue formulaire équipe qualité -->
    <record id="view_stock_quality_team_form" model="ir.ui.view">
        <field name="name">stock.quality.team.form</field>
        <field name="model">stock.quality.team</field>
        <field name="arch" type="xml">
            <form string="Équipe qualité">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="leader_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Membres">
                        <field name="member_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue liste équipe qualité -->
    <record id="view_stock_quality_team_tree" model="ir.ui.view">
        <field name="name">stock.quality.team.tree</field>
        <field name="model">stock.quality.team</field>
        <field name="arch" type="xml">
            <tree string="Équipes qualité">
                <field name="name"/>
                <field name="leader_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Action équipe qualité -->
    <record id="action_stock_quality_team" model="ir.actions.act_window">
        <field name="name">Équipes qualité</field>
        <field name="res_model">stock.quality.team</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
