<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════ TRANSACTION FORM ══════════════════ -->
    <record id="view_mohasib_transaction_form" model="ir.ui.view">
        <field name="name">mohasib.transaction.form</field>
        <field name="model">mohasib.transaction</field>
        <field name="arch" type="xml">
            <form string="Transaction Mohasib">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_comptabiliser" string="Comptabiliser" type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Annuler" type="object"
                            class="btn-danger"
                            invisible="state in ('cancelled', 'done')"/>
                    <button name="%(custom_mohasib.action_report_mohasib_transaction)d"
                            string="📥 Télécharger Pièce" type="action"
                            class="btn-info"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_mohasib_chantier)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-building"
                                invisible="not chantier_id">
                            <field name="chantier_id" widget="statinfo" string="Chantier"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="📋 Classification">
                            <field name="type_transaction"/>
                            <field name="categorie_chantier"/>
                            <field name="date"/>
                            <field name="chantier_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group string="💰 Montants">
                            <field name="montant"/>
                            <field name="taux_tva"/>
                            <field name="montant_ht"/>
                            <field name="montant_tva"/>
                            <field name="taux_retenue"/>
                            <field name="montant_retenue"/>
                            <field name="montant_net" class="oe_subtotal_footer_separator"/>
                        </group>
                    </group>
                    <group>
                        <group string="📦 Détails">
                            <field name="article"/>
                            <field name="quantite"/>
                            <field name="prix_unitaire"/>
                            <field name="mode_paiement"/>
                        </group>
                        <group string="🔗 Liens">
                            <field name="move_id"/>
                            <field name="conversation_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="📝 Description">
                        <field name="description" nolabel="1" colspan="4"/>
                        <field name="description_comptable" nolabel="1" colspan="4"/>
                    </group>
                    <group string="🔤 Texte original" invisible="not texte_original">
                        <field name="texte_original" nolabel="1" colspan="4" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ══════════════════ TRANSACTION TREE ══════════════════ -->
    <record id="view_mohasib_transaction_tree" model="ir.ui.view">
        <field name="name">mohasib.transaction.tree</field>
        <field name="model">mohasib.transaction</field>
        <field name="arch" type="xml">
            <tree string="Transactions Mohasib"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="type_transaction"/>
                <field name="chantier_id"/>
                <field name="article"/>
                <field name="montant" sum="Total"/>
                <field name="montant_tva" sum="Total TVA"/>
                <field name="mode_paiement"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ══════════════════ TRANSACTION SEARCH ══════════════════ -->
    <record id="view_mohasib_transaction_search" model="ir.ui.view">
        <field name="name">mohasib.transaction.search</field>
        <field name="model">mohasib.transaction</field>
        <field name="arch" type="xml">
            <search string="Rechercher une transaction">
                <field name="name"/>
                <field name="article"/>
                <field name="chantier_id"/>
                <field name="partner_id"/>
                <filter name="filter_draft" string="Brouillon"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmé"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_done" string="Comptabilisé"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_depenses" string="Dépenses"
                        domain="[('type_transaction', '!=', 'encaissement')]"/>
                <filter name="filter_encaissements" string="Encaissements"
                        domain="[('type_transaction', '=', 'encaissement')]"/>
                <separator/>
                <filter name="filter_today" string="Aujourd'hui"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="Ce mois"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'type_transaction'}"/>
                    <filter name="group_chantier" string="Chantier"
                            context="{'group_by': 'chantier_id'}"/>
                    <filter name="group_paiement" string="Paiement"
                            context="{'group_by': 'mode_paiement'}"/>
                    <filter name="group_month" string="Mois"
                            context="{'group_by': 'date:month'}"/>
                    <filter name="group_state" string="État"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════ TRANSACTION PIVOT ══════════════════ -->
    <record id="view_mohasib_transaction_pivot" model="ir.ui.view">
        <field name="name">mohasib.transaction.pivot</field>
        <field name="model">mohasib.transaction</field>
        <field name="arch" type="xml">
            <pivot string="Analyse transactions">
                <field name="chantier_id" type="row"/>
                <field name="type_transaction" type="col"/>
                <field name="montant" type="measure"/>
                <field name="montant_tva" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ══════════════════ TRANSACTION GRAPH ══════════════════ -->
    <record id="view_mohasib_transaction_graph" model="ir.ui.view">
        <field name="name">mohasib.transaction.graph</field>
        <field name="model">mohasib.transaction</field>
        <field name="arch" type="xml">
            <graph string="Transactions par type" type="bar">
                <field name="type_transaction"/>
                <field name="montant" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════ ACTION ══════════════════ -->
    <record id="action_mohasib_transaction" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">mohasib.transaction</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_mohasib_transaction_search"/>
        <field name="context">{'search_default_filter_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune transaction encore
            </p>
            <p>
                Utilisez la saisie guidée Mohasib pour créer vos premières transactions.
            </p>
        </field>
    </record>

</odoo>
