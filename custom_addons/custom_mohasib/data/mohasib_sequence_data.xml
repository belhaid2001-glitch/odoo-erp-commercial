<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Séquence Transactions Mohasib -->
        <record id="seq_mohasib_transaction" model="ir.sequence">
            <field name="name">Transaction Mohasib</field>
            <field name="code">mohasib.transaction</field>
            <field name="prefix">MOH/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Séquence Chantiers Mohasib -->
        <record id="seq_mohasib_chantier" model="ir.sequence">
            <field name="name">Chantier Mohasib</field>
            <field name="code">mohasib.chantier</field>
            <field name="prefix">CHT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
