<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- Types de documents obligatoires pré-configurés                -->
    <!-- ============================================================ -->

    <!-- Liste des constantes CNSS Maroc -->
    <!-- Taux patronal : AF 8.98% + PF 1.05% + AMO 4.29% = 14.32% -->
    <!-- Taux salarial : 4.48% + AMO 2.26% = 6.74% -->
    <!-- SMIG BTP : 17.25 DH/h (2025) -->

    <!-- ============================================================ -->
    <!-- Action planifiée : Cron journalier alertes BTP                -->
    <!-- ============================================================ -->
    <record id="cron_btp_alertes" model="ir.cron">
        <field name="name">BTP : Vérification des alertes quotidiennes</field>
        <field name="model_id" ref="model_btp_chantier"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_alertes()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

</odoo>
