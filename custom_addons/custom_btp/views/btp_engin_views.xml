<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Vues Engin                                                    -->
    <!-- ============================================================ -->
    <record id="view_btp_engin_tree" model="ir.ui.view">
        <field name="name">btp.engin.tree</field>
        <field name="model">btp.engin</field>
        <field name="arch" type="xml">
            <tree string="Engins BTP">
                <field name="name"/>
                <field name="type_engin"/>
                <field name="immatriculation"/>
                <field name="chantier_id"/>
                <field name="compteur_heures"/>
                <field name="cout_heure"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'disponible'"
                       decoration-info="state == 'en_service'"
                       decoration-danger="state == 'en_panne'"
                       decoration-warning="state == 'en_maintenance'"/>
            </tree>
        </field>
    </record>

    <record id="view_btp_engin_form" model="ir.ui.view">
        <field name="name">btp.engin.form</field>
        <field name="model">btp.engin</field>
        <field name="arch" type="xml">
            <form string="Engin BTP">
                <header>
                    <button name="action_mettre_en_service" string="Mettre en service" type="object" class="btn-primary"
                            invisible="state != 'disponible'"/>
                    <button name="action_declarer_panne" string="Déclarer panne" type="object" class="btn-danger"
                            invisible="state not in ('en_service', 'disponible')"/>
                    <button name="action_envoyer_maintenance" string="Envoyer en maintenance" type="object" class="btn-warning"
                            invisible="state == 'en_maintenance'"/>
                    <button name="action_rendre_disponible" string="Rendre disponible" type="object"
                            invisible="state == 'disponible'"/>
                    <field name="state" widget="statusbar" statusbar_visible="disponible,en_service"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="type_engin"/>
                            <field name="immatriculation"/>
                            <field name="equipment_id"/>
                        </group>
                        <group string="Utilisation">
                            <field name="chantier_id"/>
                            <field name="compteur_heures"/>
                            <field name="consommation_gasoil_heure"/>
                            <field name="cout_heure"/>
                        </group>
                    </group>
                    <group string="Documents">
                        <field name="assurance_date_fin"/>
                        <field name="visite_technique_date_fin"/>
                        <field name="alerte_assurance" widget="boolean" decoration-danger="alerte_assurance"/>
                        <field name="alerte_visite" widget="boolean" decoration-danger="alerte_visite"/>
                    </group>
                    <notebook>
                        <page string="Pointages engin">
                            <field name="pointage_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="chantier_id"/>
                                    <field name="operateur_id"/>
                                    <field name="heures_utilisation"/>
                                    <field name="gasoil_litres"/>
                                    <field name="cout_total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Maintenances">
                            <field name="maintenance_ids">
                                <tree>
                                    <field name="date_planifiee"/>
                                    <field name="date_realisee"/>
                                    <field name="type"/>
                                    <field name="description"/>
                                    <field name="cout_total"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_btp_engin_kanban" model="ir.ui.view">
        <field name="name">btp.engin.kanban</field>
        <field name="model">btp.engin</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="type_engin"/>
                <field name="immatriculation"/>
                <field name="chantier_id"/>
                <field name="state"/>
                <field name="image"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('btp.engin', 'image', record.id.raw_value)" alt="Engin" class="o_image_64_cover"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="type_engin"/></div>
                                <div><field name="immatriculation"/></div>
                                <div><field name="chantier_id"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_btp_engin" model="ir.actions.act_window">
        <field name="name">Engins</field>
        <field name="res_model">btp.engin</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <!-- ============================================================ -->
    <!-- Vues Maintenance                                              -->
    <!-- ============================================================ -->
    <record id="view_btp_maintenance_tree" model="ir.ui.view">
        <field name="name">btp.maintenance.tree</field>
        <field name="model">btp.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenances">
                <field name="engin_id"/>
                <field name="type"/>
                <field name="date_planifiee"/>
                <field name="date_realisee"/>
                <field name="fournisseur_id"/>
                <field name="cout_total"/>
            </tree>
        </field>
    </record>

    <record id="view_btp_maintenance_form" model="ir.ui.view">
        <field name="name">btp.maintenance.form</field>
        <field name="model">btp.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <sheet>
                    <group>
                        <group>
                            <field name="engin_id"/>
                            <field name="type"/>
                            <field name="fournisseur_id"/>
                        </group>
                        <group>
                            <field name="date_planifiee"/>
                            <field name="date_realisee"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="cout_pieces"/>
                            <field name="cout_main_oeuvre"/>
                            <field name="cout_total"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description de la maintenance..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_btp_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenances</field>
        <field name="res_model">btp.maintenance</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
