<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template de rapport personnalisé -->
    <template id="report_sale_order_custom_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@class='page']" position="inside">
            <div class="row mt-3" t-if="doc.delivery_note">
                <div class="col-12">
                    <strong>Instructions de livraison :</strong>
                    <p t-field="doc.delivery_note"/>
                </div>
            </div>
            <div class="row mt-2" t-if="doc.customer_reference">
                <div class="col-12">
                    <strong>Référence client :</strong>
                    <span t-field="doc.customer_reference"/>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
