<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== WIZARD FORM ==================== -->
    <record id="view_contact_import_wizard_form" model="ir.ui.view">
        <field name="name">contact.import.wizard.form</field>
        <field name="model">contact.import.wizard</field>
        <field name="arch" type="xml">
            <form string="📥 Importer des contacts">
                <sheet>
                    <!-- État brouillon : formulaire d'upload -->
                    <div invisible="state != 'draft'">
                        <div class="alert alert-info" role="alert" style="margin-bottom: 16px;">
                            <h4><i class="fa fa-lightbulb-o"/> Import simplifié de contacts</h4>
                            <ol style="margin-top: 8px;">
                                <li><strong>Téléchargez le template</strong> → remplissez-le dans Excel</li>
                                <li><strong>Enregistrez en CSV</strong> (séparateur point-virgule ;)</li>
                                <li><strong>Importez ici</strong> → les régions, codes postaux et pays sont remplis automatiquement !</li>
                            </ol>
                            <p style="margin-top: 8px; margin-bottom: 0;">
                                <i class="fa fa-info-circle"/> Les doublons (même nom ou même email) sont détectés et ignorés.
                            </p>
                        </div>

                        <group>
                            <group>
                                <button name="action_download_template" type="object"
                                        string="📋 Télécharger le template CSV"
                                        class="btn-primary"
                                        icon="fa-download"
                                        colspan="2"/>
                            </group>
                        </group>

                        <separator string="Fichier à importer"/>
                        <group>
                            <group>
                                <field name="file_data" filename="file_name"
                                       widget="binary"
                                       string="Fichier CSV"/>
                                <field name="file_name" invisible="1"/>
                            </group>
                        </group>
                    </div>

                    <!-- État terminé : résultats -->
                    <div invisible="state != 'done'">
                        <div class="alert alert-success" role="alert"
                             invisible="error_count != 0"
                             style="margin-bottom: 16px;">
                            <h4><i class="fa fa-check-circle"/> Import terminé avec succès !</h4>
                        </div>
                        <div class="alert alert-warning" role="alert"
                             invisible="error_count == 0"
                             style="margin-bottom: 16px;">
                            <h4><i class="fa fa-exclamation-triangle"/> Import terminé avec des avertissements</h4>
                        </div>

                        <group>
                            <group string="📊 Résumé">
                                <field name="import_count" string="✅ Contacts créés"/>
                                <field name="error_count" string="⚠️ Lignes ignorées"/>
                            </group>
                        </group>

                        <group invisible="error_count == 0">
                            <separator string="Détail des avertissements"/>
                            <field name="error_log" nolabel="1"
                                   widget="text" readonly="1"
                                   style="font-family: monospace; white-space: pre-wrap;"/>
                        </group>
                    </div>

                    <field name="state" invisible="1"/>
                </sheet>

                <footer>
                    <button name="action_import" type="object"
                            string="🚀 Importer"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_contact_import_wizard" model="ir.actions.act_window">
        <field name="name">📥 Importer des contacts (CSV)</field>
        <field name="res_model">contact.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
