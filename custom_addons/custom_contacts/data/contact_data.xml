<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Segments par défaut -->
        <record id="segment_pme" model="contact.segment">
            <field name="name">PME</field>
            <field name="description">Petites et Moyennes Entreprises</field>
            <field name="color">1</field>
        </record>

        <record id="segment_grande_entreprise" model="contact.segment">
            <field name="name">Grande Entreprise</field>
            <field name="description">Grandes entreprises et multinationales</field>
            <field name="color">2</field>
        </record>

        <record id="segment_particulier" model="contact.segment">
            <field name="name">Particulier</field>
            <field name="description">Clients particuliers</field>
            <field name="color">4</field>
        </record>

        <record id="segment_secteur_public" model="contact.segment">
            <field name="name">Secteur Public</field>
            <field name="description">Administrations et établissements publics</field>
            <field name="color">5</field>
        </record>

        <record id="segment_revendeur" model="contact.segment">
            <field name="name">Revendeur</field>
            <field name="description">Partenaires revendeurs et distributeurs</field>
            <field name="color">10</field>
        </record>

    </data>
</odoo>
