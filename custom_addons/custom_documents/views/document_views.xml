<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== DOCUMENT FOLDER ==================== -->

    <!-- Tree view - Dossiers -->
    <record id="view_document_folder_tree" model="ir.ui.view">
        <field name="name">document.folder.tree</field>
        <field name="model">document.folder</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="document_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Form view - Dossiers -->
    <record id="view_document_folder_form" model="ir.ui.view">
        <field name="name">document.folder.form</field>
        <field name="model">document.folder</field>
        <field name="arch" type="xml">
            <form string="Dossier">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom du dossier"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="parent_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                            <field name="document_count"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description du dossier..."/>
                    <notebook>
                        <page string="Sous-dossiers" name="subfolders">
                            <field name="child_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="document_count"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Documents" name="documents">
                            <field name="document_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="document_type"/>
                                    <field name="state"/>
                                    <field name="responsible_id"/>
                                    <field name="create_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== DOCUMENT ==================== -->

    <!-- Tree view - Documents -->
    <record id="view_document_document_tree" model="ir.ui.view">
        <field name="name">document.document.tree</field>
        <field name="model">document.document</field>
        <field name="arch" type="xml">
            <tree decoration-danger="is_expired" decoration-muted="state == 'archived'">
                <field name="name"/>
                <field name="folder_id"/>
                <field name="document_type"/>
                <field name="file_name"/>
                <field name="partner_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'validated'"
                       decoration-muted="state == 'archived'"/>
                <field name="version"/>
                <field name="expiration_date" optional="show"/>
                <field name="is_expired" invisible="1"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- Form view - Documents -->
    <record id="view_document_document_form" model="ir.ui.view">
        <field name="name">document.document.form</field>
        <field name="model">document.document</field>
        <field name="arch" type="xml">
            <form string="Document">
                <header>
                    <button name="action_validate" string="&#9989; Valider"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            help="Valider ce document pour le rendre officiel"/>
                    <button name="action_archive" string="&#128451; Archiver"
                            type="object"
                            invisible="state != 'validated'"
                            confirm="Archiver ce document ? Il ne sera plus modifiable."/>
                    <button name="action_reset_draft" string="&#128260; Remettre en brouillon"
                            type="object"
                            invisible="state == 'draft'"/>
                    <button name="action_new_version" string="&#128196; Nouvelle version"
                            type="object" class="btn-secondary"
                            invisible="state == 'archived'"
                            help="Créer une nouvelle version de ce document"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,validated,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom du document"/></h1>
                    </div>
                    <group>
                        <group string="&#128194; Classement">
                            <field name="folder_id"
                                   help="Dossier de rangement du document"/>
                            <field name="document_type"
                                   help="Type de document (contrat, facture, rapport, etc.)"/>
                            <field name="partner_id"
                                   help="Client/fournisseur associé au document"/>
                            <field name="version"
                                   help="Numéro de version actuel"/>
                        </group>
                        <group string="&#128100; Responsabilité">
                            <field name="responsible_id" widget="many2one_avatar_user"
                                   help="Personne responsable de ce document"/>
                            <field name="expiration_date"
                                   help="Date d'expiration (contrats, certificats...)"/>
                            <field name="is_expired"
                                   help="Indique si le document est expiré"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="file" filename="file_name"
                               help="Téléversez le fichier du document"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"
                               help="Étiquettes pour organiser et retrouver les documents"/>
                    </group>
                    <notebook>
                        <page string="&#128221; Notes" name="notes">
                            <field name="notes" placeholder="Contexte, références, instructions particulières..."
                                   help="Notes complémentaires sur ce document"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban view - Documents -->
    <record id="view_document_document_kanban" model="ir.ui.view">
        <field name="name">document.document.kanban</field>
        <field name="model">document.document</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="folder_id">
                <field name="name"/>
                <field name="folder_id"/>
                <field name="document_type"/>
                <field name="state"/>
                <field name="responsible_id"/>
                <field name="is_expired"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.is_expired.raw_value ? 'oe_kanban_color_9' : ''}">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'draft': 'info', 'validated': 'success', 'archived': 'default'}}"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="document_type"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="responsible_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search view - Documents -->
    <record id="view_document_document_search" model="ir.ui.view">
        <field name="name">document.document.search</field>
        <field name="model">document.document</field>
        <field name="arch" type="xml">
            <search string="Rechercher un document">
                <field name="name"/>
                <field name="folder_id"/>
                <field name="partner_id"/>
                <field name="responsible_id"/>
                <field name="document_type"/>
                <separator/>
                <filter string="Brouillon" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Validé" name="validated" domain="[('state', '=', 'validated')]"/>
                <filter string="Archivé" name="archived" domain="[('state', '=', 'archived')]"/>
                <separator/>
                <filter string="Expiré" name="expired" domain="[('is_expired', '=', True)]"/>
                <filter string="Expire bientôt (30j)" name="expiring_soon"
                        domain="[('expiration_date', '!=', False),
                                 ('expiration_date', '&lt;=', (context_today() + datetime.timedelta(days=30)).strftime('%%Y-%%m-%%d')),
                                 ('expiration_date', '&gt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <filter string="Mes documents" name="my_documents"
                        domain="[('responsible_id', '=', uid)]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="Dossier" name="group_folder" context="{'group_by': 'folder_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'document_type'}"/>
                    <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Responsable" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== TAGS ==================== -->

    <record id="view_document_tag_tree" model="ir.ui.view">
        <field name="name">document.tag.tree</field>
        <field name="model">document.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>

</odoo>
