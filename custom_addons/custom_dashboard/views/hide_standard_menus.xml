<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        =================================================================
        PERSONNALISATION DES MENUS - ERP Commercial
        =================================================================
        Nos modules custom étendent les menus standard Odoo.
        On les rebrand avec nos noms et icônes personnalisés.
        On réinitialise les groups_id pour que tous les utilisateurs y accèdent.
    -->

    <!-- ==================== REBRANDING DES MENUS EXISTANTS ==================== -->

    <!-- Ventes → Icône personnalisée ERP Commercial -->
    <record id="sale.sale_menu_root" model="ir.ui.menu">
        <field name="name">Ventes</field>
        <field name="web_icon">custom_sale,static/description/icon.png</field>
        <field name="groups_id" eval="[(5, 0, 0)]"/>
    </record>

    <!-- Achats → Icône personnalisée ERP Commercial -->
    <record id="purchase.menu_purchase_root" model="ir.ui.menu">
        <field name="name">Achats</field>
        <field name="web_icon">custom_purchase,static/description/icon.png</field>
        <field name="groups_id" eval="[(5, 0, 0)]"/>
    </record>

    <!-- Stock / Inventaire → Icône personnalisée ERP Commercial -->
    <record id="stock.menu_stock_root" model="ir.ui.menu">
        <field name="name">Stock &amp; Inventaire</field>
        <field name="web_icon">custom_stock,static/description/icon.png</field>
        <field name="groups_id" eval="[(5, 0, 0)]"/>
    </record>

    <!-- Comptabilité / Facturation → Icône personnalisée ERP Commercial -->
    <record id="account.menu_finance" model="ir.ui.menu">
