        <field name="name">Contacts</field>
        <field name="web_icon">custom_contacts,static/description/icon.png</field>
        <field name="groups_id" eval="[(5, 0, 0)]"/>
    </record>

    <!-- Employés / RH → Icône personnalisée ERP Commercial -->
    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="name">Ressources Humaines</field>
        <field name="web_icon">custom_hr,static/description/icon.png</field>
