<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         RAPPORT PDF — KPI Dashboard
         Accessible via : Tableau de Bord > Rapports
    ============================================================ -->

    <record id="action_report_dashboard_kpi" model="ir.actions.report">
        <field name="name">Rapport KPI</field>
        <field name="model">dashboard.kpi</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_dashboard.report_dashboard_kpi</field>
        <field name="report_file">custom_dashboard.report_dashboard_kpi</field>
        <field name="binding_model_id" ref="model_dashboard_kpi"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'KPI_%s' % object.name</field>
    </record>

    <!-- Action fenêtre pour sélection avant impression -->
    <record id="action_window_report_dashboard" model="ir.actions.act_window">
        <field name="name">Sélectionner les KPI à imprimer</field>
        <field name="res_model">dashboard.kpi</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun KPI</p>
            <p>Sélectionnez des KPI puis cliquez sur <b>Imprimer &gt; Rapport KPI</b></p>
        </field>
    </record>

    <template id="report_dashboard_kpi">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-7">
                                <h2 style="color: #2196F3;"><i class="fa fa-dashboard"/> Fiche Indicateur KPI</h2>
                                <h3><span t-field="doc.name"/></h3>
                            </div>
                            <div class="col-5 text-end">
                                <p><strong>Catégorie :</strong> <span t-field="doc.category"/></p>
                                <p><strong>Date :</strong> <span t-esc="context_today().strftime('%d/%m/%Y')"/></p>
                                <p><strong>Séquence :</strong> <span t-field="doc.sequence"/></p>
                            </div>
                        </div>

                        <div class="row mb-3" style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                            <div class="col-6">
                                <h5 style="color: #2196F3;">Informations</h5>
                                <p><strong>Icône :</strong> <i t-att-class="'fa ' + (doc.icon or 'fa-bar-chart')"/> <span t-field="doc.icon"/></p>
                                <p><strong>Actif :</strong>
                                    <span t-if="doc.active" style="color: #28a745; font-weight: bold;">Oui</span>
                                    <span t-else="" style="color: #dc3545; font-weight: bold;">Non</span>
                                </p>
                            </div>
                            <div class="col-6">
                                <h5 style="color: #2196F3;">Métadonnées</h5>
                                <p><strong>Créé par :</strong> <span t-field="doc.create_uid"/></p>
                                <p><strong>Dernière modification :</strong> <span t-field="doc.write_date" t-options='{"widget": "date"}'/></p>
                            </div>
                        </div>

                        <div t-if="doc.description" class="mt-3" style="background: #e3f2fd; padding: 15px; border-radius: 8px;">
                            <h5><i class="fa fa-info-circle" style="color: #2196F3;"/> Description</h5>
                            <p t-field="doc.description"/>
                        </div>

                        <div class="mt-4 text-center" style="font-size: 10px; color: #6c757d;">
                            <p>Document généré automatiquement — ERP Commercial</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
