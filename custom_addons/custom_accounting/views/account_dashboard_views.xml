<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Filtres recherche personnalisés -->
    <record id="view_account_move_search_custom" model="ir.ui.view">
        <field name="name">account.move.search.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter name="overdue" string="En retard"
                        domain="[('days_overdue', '>', 0)]"/>
                <filter name="high_risk" string="Risque élevé"
                        domain="[('risk_level', 'in', ['high', 'critical'])]"/>
                <filter name="reminder_sent" string="Relancé"
                        domain="[('payment_reminder_sent', '=', True)]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_risk" string="Niveau de risque"
                            context="{'group_by': 'risk_level'}"/>
                    <filter name="group_overdue" string="Jours de retard"
                            context="{'group_by': 'days_overdue'}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
