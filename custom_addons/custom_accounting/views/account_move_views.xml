<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extension vue formulaire facture -->
    <record id="view_account_move_form_custom" model="ir.ui.view">
        <field name="name">account.move.form.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_payment_reminder"
                        string="Envoyer relance"
                        type="object"
                        class="btn-warning"
                        invisible="payment_state in ('paid', 'reversed') or move_type != 'out_invoice'"/>
                <button name="action_validate_invoice"
                        string="Valider"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'posted' or validated_by"
                        groups="account.group_account_manager"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Suivi &amp; Relances" name="tracking_reminders"
                      invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group>
                        <group string="Relances">
                            <field name="payment_reminder_sent"/>
                            <field name="last_reminder_date"/>
                            <field name="reminder_count"/>
                            <field name="days_overdue"/>
                        </group>
                        <group string="Risque &amp; Validation">
                            <field name="risk_level" widget="badge"
                                   decoration-success="risk_level == 'low'"
                                   decoration-warning="risk_level == 'medium'"
                                   decoration-danger="risk_level in ('high', 'critical')"/>
                            <field name="validated_by"/>
                            <field name="validation_date"/>
                        </group>
                    </group>
                    <field name="internal_notes"
                           placeholder="Notes internes sur cette facture..."/>
                </page>
                <page string="Chèques" name="cheques">
                    <field name="cheque_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="cheque_type"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                            <field name="date"/>
                            <field name="due_date"/>
                            <field name="bank_id"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'cleared'"
                                   decoration-warning="state == 'deposited'"
                                   decoration-danger="state == 'returned'"/>
                        </tree>
                    </field>
                </page>
                <page string="Analytique" name="analytic_custom">
                    <group>
                        <field name="analytic_tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extension vue liste factures -->
    <record id="view_account_move_tree_custom" model="ir.ui.view">
        <field name="name">account.move.tree.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="days_overdue" optional="show"/>
                <field name="risk_level" optional="show" widget="badge"
                       decoration-success="risk_level == 'low'"
                       decoration-warning="risk_level == 'medium'"
                       decoration-danger="risk_level in ('high', 'critical')"/>
                <field name="reminder_count" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
