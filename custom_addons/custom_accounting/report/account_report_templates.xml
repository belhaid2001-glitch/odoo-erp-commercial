<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rapport d'impression de chèque -->
    <record id="action_report_cheque" model="ir.actions.report">
        <field name="name">Impression de chèque</field>
        <field name="model">account.cheque</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_accounting.report_cheque_template</field>
        <field name="report_file">custom_accounting.report_cheque_template</field>
        <field name="binding_model_id" ref="model_account_cheque"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_cheque_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: monospace;">
                        <div style="margin-top: 50px; margin-bottom: 30px;">
                            <div class="row">
                                <div class="col-8">
                                    <h3>CHÈQUE</h3>
                                </div>
                                <div class="col-4 text-end">
                                    <p><strong>Date:</strong> <span t-field="doc.date"/></p>
                                </div>
                            </div>
                        </div>

                        <div class="row" style="margin-bottom: 20px;">
                            <div class="col-12">
                                <p><strong>Payez à l'ordre de :</strong>
                                   <span t-field="doc.partner_id" style="font-size: 16px;"/></p>
                            </div>
                        </div>

                        <div class="row" style="margin-bottom: 20px;">
                            <div class="col-8">
                                <p><strong>La somme de :</strong>
                                   <span t-field="doc.amount"
                                         t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                         style="font-size: 18px; font-weight: bold;"/></p>
                            </div>
                            <div class="col-4 text-end" style="border: 2px solid #000; padding: 10px;">
                                <span t-field="doc.amount"
                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                      style="font-size: 20px; font-weight: bold;"/>
                            </div>
                        </div>

                        <div class="row" style="margin-top: 30px;" t-if="doc.memo">
                            <div class="col-12">
                                <p><strong>Mémo :</strong> <span t-field="doc.memo"/></p>
                            </div>
                        </div>

                        <div class="row" style="margin-top: 50px;">
                            <div class="col-6">
                                <p><strong>Banque :</strong> <span t-field="doc.bank_id"/></p>
                            </div>
                            <div class="col-6 text-end">
                                <p>_______________________________</p>
                                <p>Signature autorisée</p>
                            </div>
                        </div>

                        <div class="row" style="margin-top: 10px;">
                            <div class="col-12 text-center">
                                <p style="font-size: 10px; color: #666;">
                                    Chèque N° <span t-field="doc.name"/> |
                                    Échéance : <span t-field="doc.due_date"/>
                                </p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
