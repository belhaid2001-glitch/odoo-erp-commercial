<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         RAPPORT PDF — Facture personnalisée (complément au cheque existant)
         Accessible via : Comptabilité > Rapports
    ============================================================ -->

    <record id="action_report_account_move_custom" model="ir.actions.report">
        <field name="name">Rapport facture personnalisé</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_accounting.report_account_move_custom</field>
        <field name="report_file">custom_accounting.report_account_move_custom</field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Facture_%s' % object.name</field>
    </record>

    <!-- Action fenêtre pour sélection avant impression -->
    <record id="action_window_report_account_move" model="ir.actions.act_window">
        <field name="name">Sélectionner les factures à imprimer</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune facture</p>
            <p>Sélectionnez des factures puis cliquez sur <b>Imprimer &gt; Rapport facture personnalisé</b></p>
        </field>
    </record>

    <template id="report_account_move_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-7">
                                <h2 style="color: #495057;"><i class="fa fa-file-text-o"/> Facture</h2>
                                <h3><span t-field="doc.name"/></h3>
                            </div>
                            <div class="col-5 text-end">
                                <p><strong>Date :</strong> <span t-field="doc.invoice_date"/></p>
                                <p><strong>Échéance :</strong> <span t-field="doc.invoice_date_due"/></p>
                                <p t-if="doc.risk_level"><strong>Risque :</strong>
                                    <span t-if="doc.risk_level == 'low'" style="color: #28a745;">Faible</span>
                                    <span t-if="doc.risk_level == 'medium'" style="color: #ffc107;">Moyen</span>
                                    <span t-if="doc.risk_level == 'high'" style="color: #dc3545;">Élevé</span>
                                    <span t-if="doc.risk_level == 'critical'" style="color: #dc3545; font-weight: bold;">Critique</span>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3" style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                            <div class="col-6">
                                <h5>Client / Fournisseur</h5>
                                <p><strong><span t-field="doc.partner_id"/></strong></p>
                                <span t-field="doc.partner_id" t-options='{"widget": "contact", "fields": ["address", "phone", "email"]}'/>
                            </div>
                            <div class="col-6">
                                <h5>Informations</h5>
                                <p><strong>Référence :</strong> <span t-field="doc.ref"/></p>
                                <p t-if="doc.days_overdue"><strong>Jours de retard :</strong>
                                    <span t-att-style="'color: %s; font-weight: bold;' % ('#dc3545' if doc.days_overdue > 30 else '#ffc107' if doc.days_overdue > 0 else '#28a745')">
                                        <span t-field="doc.days_overdue"/> jours
                                    </span>
                                </p>
                                <p t-if="doc.last_reminder_date"><strong>Dernier rappel :</strong> <span t-field="doc.last_reminder_date"/></p>
                                <p t-if="doc.reminder_count"><strong>Rappels envoyés :</strong> <span t-field="doc.reminder_count"/></p>
                            </div>
                        </div>

                        <h4 class="mt-4 mb-3" style="color: #495057;">Lignes de facture</h4>
                        <table class="table table-sm table-bordered">
                            <thead style="background: #495057; color: #fff;">
                                <tr>
                                    <th>Description</th>
                                    <th class="text-center">Qté</th>
                                    <th class="text-end">Prix unit.</th>
                                    <th class="text-center">Remise (%)</th>
                                    <th class="text-end">Montant</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.invoice_line_ids.filtered(lambda l: not l.display_type)" t-as="line">
                                    <tr>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-center"><span t-field="line.quantity"/></td>
                                        <td class="text-end"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        <td class="text-center"><span t-field="line.discount"/>%</td>
                                        <td class="text-end"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row mt-3">
                            <div class="col-6">
                                <div t-if="doc.analytic_tag_ids" class="mb-3">
                                    <strong>Tags analytiques :</strong>
                                    <t t-foreach="doc.analytic_tag_ids" t-as="tag">
                                        <span class="badge" style="background: #495057; color: #fff; margin: 2px;">
                                            <span t-field="tag.name"/>
                                        </span>
                                    </t>
                                </div>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Montant HT</strong></td>
                                        <td class="text-end"><span t-field="doc.amount_untaxed" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                    <tr>
                                        <td>Taxes</td>
                                        <td class="text-end"><span t-field="doc.amount_tax" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                    <tr style="font-weight: bold; border-top: 2px solid #495057;">
                                        <td>Total TTC</td>
                                        <td class="text-end"><span t-field="doc.amount_total" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                    <tr>
                                        <td>Montant dû</td>
                                        <td class="text-end" style="font-weight: bold; color: #dc3545;"><span t-field="doc.amount_residual" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div t-if="doc.narration" class="mt-3">
                            <h5>Notes</h5>
                            <div t-field="doc.narration"/>
                        </div>

                        <div class="mt-4 text-center" style="font-size: 10px; color: #6c757d;">
                            <p>Document généré automatiquement — ERP Commercial</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
