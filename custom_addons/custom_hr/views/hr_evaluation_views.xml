<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire évaluation -->
    <record id="view_hr_evaluation_form" model="ir.ui.view">
        <field name="name">hr.evaluation.form</field>
        <field name="model">hr.evaluation</field>
        <field name="arch" type="xml">
            <form string="Évaluation">
                <header>
                    <button name="action_start" string="&#9654; Commencer"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            help="Démarrer le processus d'évaluation"/>
                    <button name="action_done" string="&#9989; Terminer"
                            type="object" class="btn-success"
                            invisible="state != 'in_progress'"
                            confirm="Terminer cette évaluation ? Le score final sera figé."/>
                    <button name="action_cancel" string="Annuler"
                            type="object"
                            invisible="state in ('done', 'cancelled')"
                            confirm="Annuler cette évaluation ?"/>
                    <button name="action_reset_draft" string="&#128260; Brouillon"
                            type="object"
                            invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="&#128100; Employé">
                            <field name="employee_id"
                                   help="Employé évalué"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="evaluator_id" widget="many2one_avatar_user"
                                   help="Personne réalisant l'évaluation"/>
                        </group>
                        <group string="&#128197; Période &amp; Résultat">
                            <field name="date"/>
                            <field name="evaluation_type"
                                   help="Type d'évaluation : annuelle, mi-parcours, stage..."/>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="global_score"
                                   help="Score global calculé automatiquement"/>
                            <field name="global_rating" widget="badge"
                                   decoration-success="global_rating in ('good', 'excellent')"
                                   decoration-warning="global_rating == 'satisfactory'"
                                   decoration-danger="global_rating in ('insufficient', 'to_improve')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="&#127942; Notation" name="scores">
                            <div class="alert alert-info" role="alert" style="margin-bottom:10px;">
                                <i class="fa fa-info-circle"/> Notez chaque critère de 1 (insuffisant) à 5 (excellent). Le score global est calculé automatiquement.
                            </div>
                            <group>
                                <group string="&#128200; Performance">
                                    <field name="score_quality" widget="radio"
                                           help="Qualité du travail fourni"/>
                                    <field name="score_productivity" widget="radio"
                                           help="Volume et rapidité d'exécution"/>
                                    <field name="score_initiative" widget="radio"
                                           help="Prise d'initiative et proactivité"/>
                                </group>
                                <group string="&#129309; Comportement">
                                    <field name="score_teamwork" widget="radio"
                                           help="Esprit d'équipe et collaboration"/>
                                    <field name="score_punctuality" widget="radio"
                                           help="Ponctualité et respect des délais"/>
                                    <field name="score_communication" widget="radio"
                                           help="Communication orale et écrite"/>
                                </group>
                            </group>
                        </page>
                        <page string="&#127919; Objectifs" name="goals">
                            <field name="goal_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="deadline"/>
                                    <field name="weight"/>
                                    <field name="achievement" widget="progressbar"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'achieved'"
                                           decoration-warning="status == 'in_progress'"
                                           decoration-danger="status == 'not_achieved'"
                                           decoration-info="status == 'not_started'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="&#128172; Commentaires" name="comments">
                            <group>
                                <group string="&#128269; Évaluation">
                                    <field name="strengths"
                                           placeholder="Points forts : compétences techniques, leadership, créativité..."
                                           help="Décrivez les points forts de l'employé"/>
                                    <field name="improvements"
                                           placeholder="Axes d'amélioration : gestion du temps, communication, rigueur..."
                                           help="Identifiez les domaines à travailler"/>
                                </group>
                                <group string="&#128640; Prochaine période">
                                    <field name="objectives"
                                           placeholder="Objectifs : certifications à obtenir, projets à mener, compétences à développer..."
                                           help="Définissez les objectifs pour la prochaine période"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="evaluator_comments"
                                           placeholder="Avis général de l'évaluateur..."
                                           help="Commentaires libres du manager"/>
                                </group>
                                <group>
                                    <field name="employee_comments"
                                           placeholder="Réponse et remarques de l'employé..."
                                           help="L'employé peut donner son retour ici"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue liste évaluation -->
    <record id="view_hr_evaluation_tree" model="ir.ui.view">
        <field name="name">hr.evaluation.tree</field>
        <field name="model">hr.evaluation</field>
        <field name="arch" type="xml">
            <tree string="Évaluations"
                  decoration-success="global_rating in ('good', 'excellent')"
                  decoration-warning="global_rating == 'satisfactory'"
                  decoration-danger="global_rating in ('insufficient', 'to_improve')">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="evaluator_id"/>
                <field name="date"/>
                <field name="evaluation_type"/>
                <field name="global_score"/>
                <field name="global_rating" widget="badge"
                       decoration-success="global_rating in ('good', 'excellent')"
                       decoration-warning="global_rating == 'satisfactory'"
                       decoration-danger="global_rating in ('insufficient', 'to_improve')"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- Vue pivot -->
    <record id="view_hr_evaluation_pivot" model="ir.ui.view">
        <field name="name">hr.evaluation.pivot</field>
        <field name="model">hr.evaluation</field>
        <field name="arch" type="xml">
            <pivot string="Évaluations">
                <field name="department_id" type="row"/>
                <field name="evaluation_type" type="col"/>
                <field name="global_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Vue graphique -->
    <record id="view_hr_evaluation_graph" model="ir.ui.view">
        <field name="name">hr.evaluation.graph</field>
        <field name="model">hr.evaluation</field>
        <field name="arch" type="xml">
            <graph string="Évaluations" type="bar">
                <field name="department_id"/>
                <field name="global_score" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action évaluations -->
    <record id="action_hr_evaluation" model="ir.actions.act_window">
        <field name="name">Évaluations</field>
        <field name="res_model">hr.evaluation</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre première évaluation
            </p>
            <p>
                Évaluez vos employés sur différents critères de performance
                et suivez leur évolution dans le temps.
            </p>
        </field>
    </record>
</odoo>
