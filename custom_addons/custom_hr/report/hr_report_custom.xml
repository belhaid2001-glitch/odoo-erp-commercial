<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         RAPPORT PDF — Fiche Employé + Évaluation
         Accessible via : RH > Rapports
    ============================================================ -->

    <record id="action_report_hr_employee_card" model="ir.actions.report">
        <field name="name">Fiche employé</field>
        <field name="model">hr.employee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_hr.report_hr_employee_card</field>
        <field name="report_file">custom_hr.report_hr_employee_card</field>
        <field name="binding_model_id" ref="model_hr_employee"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Fiche_%s' % object.name</field>
    </record>

    <record id="action_report_hr_evaluation" model="ir.actions.report">
        <field name="name">Rapport d'évaluation</field>
        <field name="model">hr.evaluation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_hr.report_hr_evaluation</field>
        <field name="report_file">custom_hr.report_hr_evaluation</field>
        <field name="binding_model_id" ref="model_hr_evaluation"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Evaluation_%s' % object.name</field>
    </record>

    <!-- Actions fenêtre pour sélection avant impression -->
    <record id="action_window_report_hr_employee" model="ir.actions.act_window">
        <field name="name">Sélectionner les employés à imprimer</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun employé</p>
            <p>Sélectionnez des employés puis cliquez sur <b>Imprimer &gt; Fiche employé</b></p>
        </field>
    </record>

    <record id="action_window_report_hr_evaluation" model="ir.actions.act_window">
        <field name="name">Sélectionner les évaluations à imprimer</field>
        <field name="res_model">hr.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune évaluation</p>
            <p>Sélectionnez des évaluations puis cliquez sur <b>Imprimer &gt; Rapport évaluation</b></p>
        </field>
    </record>

    <!-- Template Fiche Employé -->
    <template id="report_hr_employee_card">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-8">
                                <h2 style="color: #01666b;"><i class="fa fa-id-card"/> Fiche Employé</h2>
                                <h3><span t-field="doc.name"/></h3>
                                <p t-if="doc.job_title" style="font-size: 16px; color: #6c757d;"><span t-field="doc.job_title"/></p>
                            </div>
                            <div class="col-4 text-end">
                                <img t-if="doc.image_128" t-att-src="image_data_uri(doc.image_128)" style="max-height: 100px; border-radius: 50%;"/>
                            </div>
                        </div>

                        <div class="row mb-3" style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                            <div class="col-6">
                                <h5 style="color: #01666b;">Informations personnelles</h5>
                                <p t-if="doc.cin"><strong>CIN :</strong> <span t-field="doc.cin"/></p>
                                <p t-if="doc.cnss_number"><strong>CNSS :</strong> <span t-field="doc.cnss_number"/></p>
                                <p t-if="doc.birthday"><strong>Date de naissance :</strong> <span t-field="doc.birthday"/></p>
                                <p t-if="doc.blood_type"><strong>Groupe sanguin :</strong> <span t-field="doc.blood_type"/></p>
                                <p t-if="doc.work_email"><strong>Email :</strong> <span t-field="doc.work_email"/></p>
                                <p t-if="doc.work_phone"><strong>Tél :</strong> <span t-field="doc.work_phone"/></p>
                            </div>
                            <div class="col-6">
                                <h5 style="color: #01666b;">Informations professionnelles</h5>
                                <p t-if="doc.department_id"><strong>Département :</strong> <span t-field="doc.department_id"/></p>
                                <p t-if="doc.parent_id"><strong>Responsable :</strong> <span t-field="doc.parent_id"/></p>
                                <p t-if="doc.employee_type_custom"><strong>Type de contrat :</strong> <span t-field="doc.employee_type_custom"/></p>
                                <p t-if="doc.hire_date"><strong>Date d'embauche :</strong> <span t-field="doc.hire_date"/></p>
                                <p t-if="doc.seniority_years"><strong>Ancienneté :</strong> <span t-field="doc.seniority_years" t-options='{"precision": 1}'/> ans</p>
                            </div>
                        </div>

                        <t t-if="doc.emergency_contact_name">
                            <div class="row mb-3" style="background: #fff3cd; padding: 10px; border-radius: 5px;">
                                <div class="col-12">
                                    <h5><i class="fa fa-phone" style="color: #dc3545;"/> Contact d'urgence</h5>
                                    <p><strong><span t-field="doc.emergency_contact_name"/></strong>
                                       — <span t-field="doc.emergency_contact_relation"/>
                                       — <span t-field="doc.emergency_contact_phone"/></p>
                                </div>
                            </div>
                        </t>

                        <div t-if="doc.evaluation_count" class="mb-3">
                            <h5 style="color: #01666b;">Évaluations</h5>
                            <p><strong>Nombre d'évaluations :</strong> <span t-field="doc.evaluation_count"/></p>
                            <p t-if="doc.last_evaluation_date"><strong>Dernière évaluation :</strong> <span t-field="doc.last_evaluation_date"/>
                               — Score : <span t-field="doc.last_evaluation_score"/>/5</p>
                        </div>

                        <div class="mt-4 text-center" style="font-size: 10px; color: #6c757d;">
                            <p>Document confidentiel — ERP Commercial</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Template Évaluation -->
    <template id="report_hr_evaluation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-7">
                                <h2 style="color: #01666b;"><i class="fa fa-star"/> Rapport d'Évaluation</h2>
                                <h3><span t-field="doc.name"/></h3>
                            </div>
                            <div class="col-5 text-end">
                                <p><strong>Date :</strong> <span t-field="doc.date"/></p>
                                <p><strong>Type :</strong> <span t-field="doc.evaluation_type"/></p>
                                <p><strong>État :</strong> <span t-field="doc.state"/></p>
                            </div>
                        </div>

                        <div class="row mb-3" style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                            <div class="col-4">
                                <h5>Employé</h5>
                                <p><strong><span t-field="doc.employee_id"/></strong></p>
                                <p t-if="doc.department_id"><span t-field="doc.department_id"/></p>
                            </div>
                            <div class="col-4">
                                <h5>Évaluateur</h5>
                                <p><span t-field="doc.evaluator_id"/></p>
                            </div>
                            <div class="col-4 text-center" style="background: #01666b; color: #fff; padding: 15px; border-radius: 8px;">
                                <h5 style="color: #fff;">Score Global</h5>
                                <p style="font-size: 32px; margin: 0;"><span t-field="doc.global_score" t-options='{"precision": 1}'/>/5</p>
                                <p t-if="doc.global_rating"><span t-field="doc.global_rating"/></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12">
                                <h5>Période évaluée : <span t-field="doc.period_start"/> — <span t-field="doc.period_end"/></h5>
                            </div>
                        </div>

                        <h4 class="mt-4 mb-3" style="color: #01666b;">Critères d'évaluation</h4>
                        <table class="table table-bordered">
                            <thead style="background: #01666b; color: #fff;">
                                <tr>
                                    <th>Critère</th>
                                    <th class="text-center">Note</th>
                                    <th>Appréciation</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td>Qualité du travail</td><td class="text-center"><span t-field="doc.score_quality"/>/5</td><td></td></tr>
                                <tr><td>Productivité</td><td class="text-center"><span t-field="doc.score_productivity"/>/5</td><td></td></tr>
                                <tr><td>Initiative</td><td class="text-center"><span t-field="doc.score_initiative"/>/5</td><td></td></tr>
                                <tr><td>Travail d'équipe</td><td class="text-center"><span t-field="doc.score_teamwork"/>/5</td><td></td></tr>
                                <tr><td>Ponctualité</td><td class="text-center"><span t-field="doc.score_punctuality"/>/5</td><td></td></tr>
                                <tr><td>Communication</td><td class="text-center"><span t-field="doc.score_communication"/>/5</td><td></td></tr>
                            </tbody>
                        </table>

                        <t t-if="doc.goal_ids">
                            <h4 class="mt-4 mb-3" style="color: #01666b;">Objectifs</h4>
                            <table class="table table-sm table-bordered">
                                <thead style="background: #e9ecef;">
                                    <tr>
                                        <th>Objectif</th>
                                        <th class="text-center">Poids (%)</th>
                                        <th class="text-center">Réalisation (%)</th>
                                        <th class="text-center">Statut</th>
                                        <th>Échéance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.goal_ids" t-as="goal">
                                        <td><span t-field="goal.name"/></td>
                                        <td class="text-center"><span t-field="goal.weight"/>%</td>
                                        <td class="text-center"><span t-field="goal.achievement"/>%</td>
                                        <td class="text-center"><span t-field="goal.status"/></td>
                                        <td><span t-field="goal.deadline"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>

                        <div t-if="doc.strengths" class="mt-3" style="background: #d4edda; padding: 10px; border-radius: 5px;">
                            <strong><i class="fa fa-thumbs-up"/> Points forts :</strong>
                            <p t-field="doc.strengths"/>
                        </div>

                        <div t-if="doc.improvements" class="mt-3" style="background: #f8d7da; padding: 10px; border-radius: 5px;">
                            <strong><i class="fa fa-exclamation-triangle"/> Axes d'amélioration :</strong>
                            <p t-field="doc.improvements"/>
                        </div>

                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <p>_______________________________</p>
                                <p>Signature Évaluateur</p>
                            </div>
                            <div class="col-6 text-center">
                                <p>_______________________________</p>
                                <p>Signature Employé</p>
                            </div>
                        </div>

                        <div class="mt-4 text-center" style="font-size: 10px; color: #6c757d;">
                            <p>Document confidentiel — ERP Commercial</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
