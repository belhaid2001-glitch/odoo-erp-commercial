<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== WIZARD ENVOI WHATSAPP ==================== -->
    <record id="view_whatsapp_send_wizard_form" model="ir.ui.view">
        <field name="name">whatsapp.send.wizard.form</field>
        <field name="model">whatsapp.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Envoyer un message WhatsApp">
                <group>
                    <group string="Destinataire">
                        <field name="is_mass_send" widget="boolean_toggle"/>
                        <field name="partner_id" invisible="is_mass_send"/>
                        <field name="phone" invisible="is_mass_send"/>
                        <field name="partner_ids" widget="many2many_tags" invisible="not is_mass_send"/>
                    </group>
                    <group string="Message">
                        <field name="template_id" options="{'no_create': True}"
                               placeholder="Choisir un template..."/>
                    </group>
                </group>
                <group>
                    <field name="message" placeholder="Bonjour, ..." nolabel="1"/>
                </group>
                <field name="model_name" invisible="1"/>
                <field name="res_id" invisible="1"/>
                <footer>
                    <button name="action_send" string="📱 Envoyer via WhatsApp"
                            type="object" class="btn-success"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_whatsapp_send_wizard" model="ir.actions.act_window">
        <field name="name">Envoyer WhatsApp</field>
        <field name="res_model">whatsapp.send.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
