<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== BOUTON WHATSAPP SUR FICHE CONTACT ==================== -->
    <record id="view_partner_form_whatsapp" model="ir.ui.view">
        <field name="name">res.partner.form.whatsapp</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Bouton stat WhatsApp -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_whatsapp_messages" type="object"
                        class="oe_stat_button" icon="fa-commenting-o"
                        invisible="whatsapp_message_count == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_value"><field name="whatsapp_message_count"/></span>
                        <span class="o_stat_text">WhatsApp</span>
                    </div>
                </button>
                <button name="action_send_whatsapp" type="object"
                        class="oe_stat_button" icon="fa-paper-plane">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Envoyer WhatsApp</span>
                    </div>
                </button>
            </xpath>

            <!-- Champs WhatsApp après le mobile -->
            <xpath expr="//field[@name='mobile']" position="after">
                <field name="whatsapp_number" placeholder="+212 6XX XX XX XX"/>
                <field name="whatsapp_opt_in" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>

    <!-- ==================== BOUTON WHATSAPP SUR BON DE COMMANDE ==================== -->
    <record id="view_sale_order_form_whatsapp" model="ir.ui.view">
        <field name="name">sale.order.form.whatsapp</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_whatsapp_sale" string="📱 WhatsApp"
                        type="object" class="btn-success"/>
            </xpath>
        </field>
    </record>

    <!-- ==================== BOUTON WHATSAPP SUR FACTURE ==================== -->
    <record id="view_account_move_form_whatsapp" model="ir.ui.view">
        <field name="name">account.move.form.whatsapp</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_whatsapp_invoice" string="📱 WhatsApp"
                        type="object" class="btn-success"
                        invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>

</odoo>
