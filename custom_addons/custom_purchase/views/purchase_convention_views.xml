<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire convention -->
    <record id="view_purchase_convention_form" model="ir.ui.view">
        <field name="name">purchase.convention.form</field>
        <field name="model">purchase.convention</field>
        <field name="arch" type="xml">
            <form string="Convention d'achat">
                <header>
                    <button name="action_activate" string="Activer"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_expire" string="Expirer"
                            type="object"
                            invisible="state != 'active'"/>
                    <button name="action_cancel" string="Annuler"
                            type="object"
                            invisible="state in ('expired', 'cancelled')"/>
                    <button name="action_reset_draft" string="Remettre en brouillon"
                            type="object"
                            invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchases"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">
                            <field name="purchase_count" widget="statinfo"
                                   string="Commandes"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="payment_term_id"/>
                            <field name="discount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="min_amount"/>
                            <field name="max_amount"/>
                            <field name="total_purchased"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Produits" name="products">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="uom_id"/>
                                    <field name="min_qty"/>
                                    <field name="max_qty"/>
                                    <field name="negotiated_price"/>
                                    <field name="discount"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Conditions" name="conditions">
                            <field name="notes"
                                   placeholder="Conditions particulières de la convention..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue liste convention -->
    <record id="view_purchase_convention_tree" model="ir.ui.view">
        <field name="name">purchase.convention.tree</field>
        <field name="model">purchase.convention</field>
        <field name="arch" type="xml">
            <tree string="Conventions d'achat"
                  decoration-success="state == 'active'"
                  decoration-muted="state in ('expired', 'cancelled')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="discount"/>
                <field name="total_purchased"/>
                <field name="purchase_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state in ('expired', 'cancelled')"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_purchase_convention" model="ir.actions.act_window">
        <field name="name">Conventions d'achat</field>
        <field name="res_model">purchase.convention</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre première convention d'achat
            </p>
            <p>
                Les conventions vous permettent de gérer vos accords cadres
                avec vos fournisseurs (prix négociés, conditions, durée).
            </p>
        </field>
    </record>
</odoo>
