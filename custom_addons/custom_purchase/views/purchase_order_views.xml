<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extension vue formulaire commande d'achat -->
    <record id="view_purchase_order_form_custom" model="ir.ui.view">
        <field name="name">purchase.order.form.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="priority" widget="priority"/>
            </xpath>

            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="supplier_reference"/>
                <field name="convention_id"/>
                <field name="purchase_type"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Conditionnement &amp; Qualité" name="packaging_quality">
                    <group>
                        <group string="Conditionnement">
                            <field name="packaging_instructions"/>
                        </group>
                        <group string="Contrôle qualité">
                            <field name="quality_check"/>
                            <field name="quality_notes"
                                   invisible="not quality_check"/>
                        </group>
                    </group>
                </page>
                <page string="Indicateurs" name="kpi">
                    <group>
                        <group>
                            <field name="total_savings"/>
                            <field name="approval_required"/>
                        </group>
                        <group>
                            <field name="reception_status" widget="badge"
                                   decoration-success="reception_status == 'complete'"
                                   decoration-warning="reception_status == 'partial'"
                                   decoration-info="reception_status == 'pending'"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extension vue liste -->
    <record id="view_purchase_order_tree_custom" model="ir.ui.view">
        <field name="name">purchase.order.tree.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="priority" widget="priority"/>
                <field name="purchase_type" optional="show"/>
                <field name="convention_id" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <field name="reception_status" optional="show" widget="badge"
                       decoration-success="reception_status == 'complete'"
                       decoration-warning="reception_status == 'partial'"/>
            </xpath>
        </field>
    </record>
</odoo>
