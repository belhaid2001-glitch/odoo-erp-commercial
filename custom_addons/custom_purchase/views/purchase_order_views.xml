<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extension vue formulaire commande d'achat -->
    <record id="view_purchase_order_form_custom" model="ir.ui.view">
        <field name="name">purchase.order.form.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="priority" widget="priority"/>
            </xpath>

            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="supplier_reference" placeholder="Réf. du fournisseur"
                       help="Référence interne du fournisseur pour cette commande"/>
                <field name="convention_id"
                       help="Sélectionnez une convention active pour bénéficier des prix négociés"/>
                <field name="purchase_type"
                       help="Classifie l'achat pour les analyses et rapports"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="&#128230; Conditionnement &amp; Qualité" name="packaging_quality">
                    <group>
                        <group string="Instructions d'emballage">
                            <field name="packaging_instructions"
                                   placeholder="Détaillez les exigences de conditionnement..."
                                   help="Ces instructions seront transmises au fournisseur"/>
                        </group>
                        <group string="Contrôle à la réception">
                            <field name="quality_check" widget="boolean_toggle"
                                   help="Activer pour exiger un contrôle qualité à la réception"/>
                            <field name="quality_notes"
                                   invisible="not quality_check"
                                   placeholder="Points de contrôle spécifiques..."/>
                        </group>
                    </group>
                </page>
                <page string="&#128200; Indicateurs" name="kpi">
                    <group>
                        <group string="Performance">
                            <field name="total_savings"
                                   help="Économies réalisées grâce à la convention fournisseur"/>
                            <field name="approval_required"
                                   help="Approbation requise automatiquement si montant &gt; 50 000 MAD"/>
                        </group>
                        <group string="Réception">
                            <field name="reception_status" widget="badge"
                                   decoration-success="reception_status == 'complete'"
                                   decoration-warning="reception_status == 'partial'"
                                   decoration-info="reception_status == 'pending'"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extension vue liste avec décorations enrichies -->
    <record id="view_purchase_order_tree_custom" model="ir.ui.view">
        <field name="name">purchase.order.tree.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="priority" widget="priority"/>
                <field name="purchase_type" optional="show" string="Type"/>
                <field name="convention_id" optional="show" string="Convention"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <field name="reception_status" optional="show" widget="badge"
                       string="Réception"
                       decoration-success="reception_status == 'complete'"
                       decoration-warning="reception_status == 'partial'"/>
            </xpath>
        </field>
    </record>
</odoo>
