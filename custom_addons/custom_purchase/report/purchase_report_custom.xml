<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         RAPPORT PDF — Bon de commande fournisseur + Convention
         Accessible via : Achats > Rapports
    ============================================================ -->

    <record id="action_report_purchase_order_custom" model="ir.actions.report">
        <field name="name">Rapport de commande fournisseur</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_purchase.report_purchase_order_custom</field>
        <field name="report_file">custom_purchase.report_purchase_order_custom</field>
        <field name="binding_model_id" ref="model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'BC_Fournisseur_%s' % object.name</field>
    </record>

    <record id="action_report_purchase_convention" model="ir.actions.report">
        <field name="name">Rapport de convention d'achat</field>
        <field name="model">purchase.convention</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_purchase.report_purchase_convention</field>
        <field name="report_file">custom_purchase.report_purchase_convention</field>
        <field name="binding_model_id" ref="model_purchase_convention"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Convention_%s' % object.name</field>
    </record>

    <!-- Actions fenêtre pour sélection avant impression -->
    <record id="action_window_report_purchase_order" model="ir.actions.act_window">
        <field name="name">Sélectionner les commandes d'achat à imprimer</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune commande d'achat</p>
            <p>Sélectionnez des commandes puis cliquez sur <b>Imprimer &gt; Rapport commande fournisseur</b></p>
        </field>
    </record>

    <record id="action_window_report_purchase_convention" model="ir.actions.act_window">
        <field name="name">Sélectionner les conventions à imprimer</field>
        <field name="res_model">purchase.convention</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune convention d'achat</p>
            <p>Sélectionnez des conventions puis cliquez sur <b>Imprimer &gt; Rapport convention</b></p>
        </field>
    </record>

    <!-- Template Commande Fournisseur -->
    <template id="report_purchase_order_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-7">
                                <h2 style="color: #00A09D;"><i class="fa fa-truck"/> Bon de Commande Fournisseur</h2>
                                <h3><span t-field="doc.name"/></h3>
                            </div>
                            <div class="col-5 text-end">
                                <p><strong>Date :</strong> <span t-field="doc.date_order" t-options='{"widget": "date"}'/></p>
                                <p><strong>Type :</strong> <span t-field="doc.purchase_type"/></p>
                                <p><strong>Acheteur :</strong> <span t-field="doc.user_id"/></p>
                            </div>
                        </div>

                        <div class="row mb-3" style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                            <div class="col-6">
                                <h5 style="color: #495057;">Fournisseur</h5>
                                <p><strong><span t-field="doc.partner_id"/></strong></p>
                                <span t-field="doc.partner_id" t-options='{"widget": "contact", "fields": ["address", "phone", "email"]}'/>
                            </div>
                            <div class="col-6">
                                <h5 style="color: #495057;">Informations</h5>
                                <p t-if="doc.supplier_reference"><strong>Réf. fournisseur :</strong> <span t-field="doc.supplier_reference"/></p>
                                <p><strong>Priorité :</strong> <span t-field="doc.priority"/></p>
                                <p t-if="doc.convention_id"><strong>Convention :</strong> <span t-field="doc.convention_id"/></p>
                                <p t-if="doc.quality_check"><i class="fa fa-check-circle" style="color: #28a745;"/> Contrôle qualité activé</p>
                            </div>
                        </div>

                        <h4 class="mt-4 mb-3" style="color: #00A09D;">Lignes de commande</h4>
                        <table class="table table-sm table-bordered">
                            <thead style="background: #00A09D; color: #fff;">
                                <tr>
                                    <th>Produit</th>
                                    <th class="text-center">Qté</th>
                                    <th class="text-end">Prix unitaire</th>
                                    <th class="text-end">Sous-total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.order_line" t-as="line">
                                    <td><span t-field="line.product_id"/></td>
                                    <td class="text-center"><span t-field="line.product_qty"/> <span t-field="line.product_uom"/></td>
                                    <td class="text-end"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    <td class="text-end"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt-3">
                            <div class="col-6">
                                <div t-if="doc.quality_notes" style="background: #fff3cd; padding: 10px; border-radius: 5px;">
                                    <strong><i class="fa fa-clipboard"/> Notes qualité :</strong>
                                    <p t-field="doc.quality_notes"/>
                                </div>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Total HT</strong></td>
                                        <td class="text-end"><span t-field="doc.amount_untaxed" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                    <tr>
                                        <td>Taxes</td>
                                        <td class="text-end"><span t-field="doc.amount_tax" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                    <tr style="font-weight: bold; border-top: 2px solid #00A09D;">
                                        <td>Total TTC</td>
                                        <td class="text-end"><span t-field="doc.amount_total" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                    <tr t-if="doc.total_savings" style="color: #28a745;">
                                        <td>Économies</td>
                                        <td class="text-end"><span t-field="doc.total_savings" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="mt-4 text-center" style="font-size: 10px; color: #6c757d;">
                            <p>Document généré automatiquement — ERP Commercial</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Template Convention -->
    <template id="report_purchase_convention">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-7">
                                <h2 style="color: #00A09D;"><i class="fa fa-handshake-o"/> Convention d'Achat</h2>
                                <h3><span t-field="doc.name"/></h3>
                            </div>
                            <div class="col-5 text-end">
                                <p><strong>État :</strong> <span t-field="doc.state"/></p>
                                <p><strong>Du :</strong> <span t-field="doc.date_start"/></p>
                                <p><strong>Au :</strong> <span t-field="doc.date_end"/></p>
                            </div>
                        </div>

                        <div class="row mb-3" style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                            <div class="col-6">
                                <h5>Fournisseur</h5>
                                <p><strong><span t-field="doc.partner_id"/></strong></p>
                            </div>
                            <div class="col-3 text-center">
                                <h5>Remise globale</h5>
                                <p style="font-size: 24px; color: #28a745;"><span t-field="doc.discount"/>%</p>
                            </div>
                            <div class="col-3 text-center">
                                <h5>Commandes</h5>
                                <p style="font-size: 24px;"><span t-field="doc.purchase_count"/></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <p><strong>Montant min :</strong> <span t-field="doc.min_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></p>
                            </div>
                            <div class="col-6">
                                <p><strong>Montant max :</strong> <span t-field="doc.max_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></p>
                            </div>
                        </div>

                        <t t-if="doc.line_ids">
                            <h4 class="mt-4 mb-3" style="color: #00A09D;">Produits conventionnés</h4>
                            <table class="table table-sm table-bordered">
                                <thead style="background: #00A09D; color: #fff;">
                                    <tr>
                                        <th>Produit</th>
                                        <th class="text-center">Qté min</th>
                                        <th class="text-center">Qté max</th>
                                        <th class="text-end">Prix négocié</th>
                                        <th class="text-center">Remise (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.line_ids" t-as="line">
                                        <td><span t-field="line.product_id"/></td>
                                        <td class="text-center"><span t-field="line.min_qty"/></td>
                                        <td class="text-center"><span t-field="line.max_qty"/></td>
                                        <td class="text-end"><span t-field="line.negotiated_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        <td class="text-center"><span t-field="line.discount"/>%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>

                        <div t-if="doc.notes" class="mt-3">
                            <h5>Notes</h5>
                            <p t-field="doc.notes"/>
                        </div>

                        <div class="mt-4 text-center" style="font-size: 10px; color: #6c757d;">
                            <p>Document généré automatiquement — ERP Commercial</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
